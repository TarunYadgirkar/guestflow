{
  "name": "guestflow",
  "version": "1.0.0",
  "description": "GuestFlow — Hyper-Personalized Arrival Orchestration",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"vite --config config/vite.config.ts\"",
    "api": "tsx api/server.ts",
    "web": "vite --config config/vite.config.ts",
    "build": "vite build --config config/vite.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'shared/**/*.ts'",
    "orchestrate": "tsx agent/orchestrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@phosphor-icons/react": "^2.1.10",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "postcss": "^8.5.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vercel/node": "^5.8.2",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
